# --- Route @pokedex/* installs through the local Verdaccio. Anything else still resolves via
# npmjs.org (or whatever your default registry is). Per-app .npmrc files inherit this. ---
@pokedex:registry=http://localhost:4873/

# --- Don't fail installs because Verdaccio is briefly down or restarting. Apps NOT using any
# @pokedex/* package will install fine without Verdaccio running. ---
fetch-retries=2
fetch-retry-mintimeout=5000
