{
  "name": "@pokedex/ui",
  "version": "0.9.2",
  "description": "Design system for the Pokédex Federation app. Wraps Gluestack v2 primitives with the project's colour tokens, typography, and Pokédex-domain components (PokemonCard, TypeBadge, ScreenContainer, PokemonGrid, LoadingState, ErrorState).",
  "source": "./src/index.ts",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "react-native": "./src/index.ts",
  "types": "./lib/typescript/index.d.ts",
  "files": [
    "src",
    "lib",
    "tailwind.preset.js",
    "global.css",
    "README.md",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "bob build",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "accessibility-report": "jest --reporters=default --reporters=@pokedex/a11y-testing/reporter"
  },
  "publishConfig": {
    "registry": "http://localhost:4873/"
  },
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "peerDependencies": {
    "@expo/html-elements": ">=0.10.0",
    "@gluestack-ui/core": ">=3.0.10",
    "@gluestack-ui/utils": ">=3.0.11",
    "@shopify/flash-list": ">=2.0.0",
    "nativewind": ">=4.1.23",
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": "*",
    "react-native-safe-area-context": "*",
    "react-native-svg": "*",
    "tailwindcss": ">=3.4 <4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@expo/html-elements": "^56.0.1",
    "@gluestack-ui/core": "^3.0.10",
    "@gluestack-ui/utils": "^3.0.11",
    "@pokedex/a11y-testing": "^0.1.2",
    "@react-native/babel-preset": "^0.85.3",
    "@react-native/jest-preset": "^0.85.3",
    "@shopify/flash-list": "^2.3.1",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.0.0",
    "babel-jest": "^29.6.3",
    "jest": "^29.6.3",
    "nativewind": "^4.1.23",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.41.0",
    "react-native-reanimated": "^4.4.0",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-svg": "^15.13.0",
    "react-test-renderer": "19.2.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@legendapp/motion": "^2.5.3"
  }
}
