{
  "name": "@pokedex/a11y-testing",
  "version": "0.1.1",
  "description": "Drop-in WCAG 2.1 / EAA accessibility testing for React Native: Jest assertion helpers, a NativeWind-aware render, a WCAG criteria catalogue, and an accessibility-report generator. No paid scanner.",
  "source": "./src/index.ts",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/index.d.ts",
  "files": [
    "src",
    "lib",
    "jest-preset.js",
    "babel.jest.js",
    "jest",
    "reporter.js",
    "wcag-criteria.js",
    "README.md",
    "!**/__tests__",
    "!**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "bob build",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "registry": "http://localhost:4873/"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "peerDependencies": {
    "@react-native/jest-preset": ">=0.80",
    "@tailwindcss/container-queries": ">=0.1",
    "@testing-library/react-native": ">=13",
    "jest": ">=29",
    "nativewind": ">=4.1",
    "react": "*",
    "react-native": "*",
    "react-native-css-interop": ">=0.1"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.85.3",
    "@tailwindcss/container-queries": "^0.1.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.2.0",
    "jest": "^29.6.3",
    "nativewind": "^4.1.23",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.41.0",
    "react-native-css-interop": "^0.1.22",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  }
}
