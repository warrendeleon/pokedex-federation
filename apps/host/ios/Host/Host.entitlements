<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Universal links. Replace the placeholder domain with the real one and host an
	     apple-app-site-association file at https://<domain>/.well-known/apple-app-site-association
	     listing this app's appID. Inert on the simulator and without a signed build; the
	     custom pokedex:// scheme is the testable path. -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:pokedex.example.com</string>
	</array>
</dict>
</plist>
