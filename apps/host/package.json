{
  "name": "Host",
  "version": "0.0.1",
  "private": true,
  "codegenConfig": {
    "name": "HostSpecs",
    "type": "modules",
    "jsSrcsDir": "specs",
    "android": {
      "javaPackageName": "com.host.specs"
    }
  },
  "scripts": {
    "android": "react-native run-android --no-packager",
    "ios": "react-native run-ios --no-packager",
    "start": "react-native start",
    "start:reset": "react-native start --reset-cache",
    "bundle:ios": "react-native bundle --platform ios --entry-file index.js --bundle-output build/ios/main.jsbundle --assets-dest build/ios --config rspack.config.mjs",
    "bundle:ios:prod": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output build/ios/main.jsbundle --assets-dest build/ios --config rspack.config.mjs",
    "bundle:android": "react-native bundle --platform android --entry-file index.js --bundle-output build/android/index.android.bundle --assets-dest build/android --config rspack.config.mjs",
    "bundle:android:prod": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output build/android/index.android.bundle --assets-dest build/android --config rspack.config.mjs",
    "lint": "eslint .",
    "test": "jest"
  },
  "dependencies": {
    "@expo/html-elements": "^56.0.1",
    "@gluestack-ui/core": "^3.0.21",
    "@gluestack-ui/utils": "^3.0.21",
