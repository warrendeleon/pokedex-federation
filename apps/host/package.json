    "@module-federation/runtime": "^2.5.0",
    "@pokedex/contracts": "^0.2.0",
    "@pokedex/ui": "^0.9.2",
    "@react-native/new-app-screen": "0.85.3",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@shopify/flash-list": "^2.3.1",
    "nativewind": "^4.2.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-reanimated": "^4.4.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-worklets": "^0.9.1",
    "react-redux": "^9.3.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@callstack/repack": "^5.2.5",
    "@callstack/repack-plugin-nativewind": "^5.2.5",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@rspack/core": "^2.0.5",
    "@rspack/plugin-react-refresh": "^2.0.1",
    "@swc/helpers": "^0.5.23",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "postcss": "^8.5.15",
    "postcss-loader": "^8.2.1",
    "prettier": "2.8.8",
